    "preview": "cd dist && node server"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "engines": {
    "node": ">=22.21.0"
  }
}
